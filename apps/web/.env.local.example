# Nakama backend (recommended)
# Public socket client key. Keep this in sync with NAKAMA_SOCKET_SERVER_KEY from .env.
# Do not put Nakama runtime HTTP, session encryption, console signing, or admin secrets
# in NEXT_PUBLIC_* browser variables.
NEXT_PUBLIC_NETWORK_BACKEND=nakama
NEXT_PUBLIC_NAKAMA_HOST=127.0.0.1
NEXT_PUBLIC_NAKAMA_PORT=7350
NEXT_PUBLIC_NAKAMA_USE_SSL=false
NEXT_PUBLIC_NAKAMA_CLIENT_KEY=dev_socket_server_key_change_me
NEXT_PUBLIC_NAKAMA_MATCH_MODULE=pdh
NEXT_PUBLIC_NAKAMA_TABLE_ID=main
# Optional: join a fixed match id instead of auto-discovery.
# NEXT_PUBLIC_NAKAMA_MATCH_ID=<match-id>

# Public Discord server invite used by landing-page CTAs.
# Use a public invite URL only. Do not use a private Discord webhook URL here.
NEXT_PUBLIC_DISCORD_INVITE_URL=https://discord.gg/YOUR_INVITE_CODE

# Server-side feature flags API (optional)
# FEATURE_FLAGS_DATABASE_URL=postgres://nakama:localdb@127.0.0.1:5432/nakama
# Or use discrete DB fields:
# FEATURE_FLAGS_DB_HOST=127.0.0.1
# FEATURE_FLAGS_DB_PORT=5432
# FEATURE_FLAGS_DB_USER=nakama
# FEATURE_FLAGS_DB_PASSWORD=localdb
# FEATURE_FLAGS_DB_NAME=nakama

# Early access signup storage. Falls back to DATABASE_URL or PG*/POSTGRES_* vars.
# EARLY_ACCESS_DATABASE_URL=postgres://nakama:localdb@127.0.0.1:5432/nakama
# Server-side Discord notification webhook for new early access signups.
# Production deploys require this while the signup form is live.
EARLY_ACCESS_DISCORD_WEBHOOK_URL=
# Legacy fallback accepted by the app if already configured:
# DISCORD_WEBHOOK_URL=

# Optional server-side email alerts for new early access signups.
# These are read only by the Next.js API route; do not prefix them with NEXT_PUBLIC_.
# For Gmail SMTP, enable Google 2-Step Verification and create a Google App Password.
# EMAIL_ALERTS_ENABLED=true
# SMTP_HOST=smtp.gmail.com
# Use 587/false if the production host blocks outbound SMTPS on 465.
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-alert-sender@gmail.com
# SMTP_PASS=your-google-app-password
# ALERT_EMAIL_FROM="Bondi Poker <your-alert-sender@gmail.com>"
# ALERT_EMAIL_TO=your-personal-or-team-email@example.com

# UI feature flags (optional)
# NEXT_PUBLIC_FF_UI_NEO_LUXURY_THEME=true
# NEXT_PUBLIC_FF_UI_QUICK_PLAY=true
# NEXT_PUBLIC_FF_UI_TABLE_V2=false
# NEXT_PUBLIC_FF_UI_DISCARD_OVERLAY_V2=false
# NEXT_PUBLIC_FF_SOCIAL_FRIENDS_LOBBY=false
# NEXT_PUBLIC_FF_PROGRESSION_MISSIONS_V1=false

# Production example:
# NEXT_PUBLIC_NAKAMA_HOST=api.example.com
# NEXT_PUBLIC_NAKAMA_PORT=443
# NEXT_PUBLIC_NAKAMA_USE_SSL=true

# Legacy backend (optional fallback)
# NEXT_PUBLIC_NETWORK_BACKEND=legacy
# NEXT_PUBLIC_WS_URL=ws://localhost:3002
